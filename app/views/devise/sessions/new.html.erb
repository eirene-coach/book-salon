<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="font-serif text-3xl font-bold text-[#C2527A] mb-2">북살롱</h1>
      <p class="text-[#7A4868] text-sm">책 한 챕터로 내 방향을 찾는 4주 코칭</p>
    </div>

    <div class="bg-white rounded-2xl shadow-[0_8px_40px_rgba(194,82,122,0.12)] p-8">
      <h2 class="font-serif text-xl font-bold text-[#1F0D18] mb-6">로그인</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4 mb-6">
          <div>
            <%= f.label :email, '이메일', class: 'block text-sm font-medium text-[#7A4868] mb-1.5' %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: 'w-full border border-pink-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#C2527A]/30 focus:border-[#C2527A] transition-all' %>
          </div>
          <div>
            <%= f.label :password, '비밀번호', class: 'block text-sm font-medium text-[#7A4868] mb-1.5' %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: 'w-full border border-pink-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#C2527A]/30 focus:border-[#C2527A] transition-all' %>
          </div>
        </div>

        <%= f.submit '로그인', class: 'w-full bg-[#C2527A] hover:bg-[#8E3A6E] text-white py-3 rounded-xl font-semibold text-sm transition-colors cursor-pointer' %>
      <% end %>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-pink-100"></div>
        </div>
        <div class="relative flex justify-center text-xs text-[#7A4868]/60">
          <span class="bg-white px-3">또는 소셜 로그인</span>
        </div>
      </div>

      <div class="space-y-3">
        <%= link_to user_google_oauth2_omniauth_authorize_path,
            data: { turbo_method: :post },
            class: 'flex items-center justify-center gap-3 w-full border border-gray-200 rounded-xl py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors' do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          구글로 로그인
        <% end %>

        <%= link_to user_kakao_omniauth_authorize_path,
            data: { turbo_method: :post },
            class: 'flex items-center justify-center gap-3 w-full bg-[#FEE500] hover:bg-[#F5DC00] rounded-xl py-3 text-sm font-medium text-[#1A1A1A] transition-colors' do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="#1A1A1A"><path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.624 1.596 4.93 4 6.28V21l3.5-2.5c.814.13 1.64.2 2.5.2 5.523 0 10-3.477 10-7.5S17.523 3 12 3z"/></svg>
          카카오로 로그인
        <% end %>
      </div>

      <p class="text-center text-sm text-[#7A4868] mt-6">
        계정이 없으신가요?
        <%= link_to '회원가입', new_user_registration_path, class: 'text-[#C2527A] font-medium hover:underline' %>
      </p>
    </div>
  </div>
</div>
