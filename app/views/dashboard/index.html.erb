<% if @enrollment %>
  <!-- 환영 + 스트릭 -->
  <div class="mb-8">
    <h1 class="font-serif text-2xl font-bold text-[#1F0D18] mb-1">
      <%= current_user.name %>님, 오늘도 이 시간을 당신 것으로 만들어보세요.
    </h1>
    <p class="text-[#7A4868] text-sm">
      <% if @streak > 0 %>
        🔥 <%= @streak %>일 연속으로 연결됐어요
      <% else %>
        오늘의 첫 기록을 남겨보세요
      <% end %>
    </p>
  </div>

  <!-- 진행률 -->
  <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(194,82,122,0.10)] p-6 mb-6">
    <div class="flex justify-between items-center mb-3">
      <span class="text-sm font-medium text-[#7A4868]">4주 여정 진행률</span>
      <span class="text-sm font-bold text-[#C2527A]"><%= @progress_percent %>%</span>
    </div>
    <div class="w-full bg-pink-100 rounded-full h-2">
      <div class="bg-[#C2527A] h-2 rounded-full transition-all duration-500"
           style="width: <%= @progress_percent %>%"></div>
    </div>
  </div>

  <!-- 오늘의 미션 -->
  <% if @today_content %>
    <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(194,82,122,0.10)] p-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-xs font-semibold text-[#C2527A] bg-pink-50 px-3 py-1 rounded-full">
          Day <%= @today_content.day_number %>
        </span>
        <span class="text-xs text-[#7A4868]">오늘의 코칭 질문</span>
      </div>
      <p class="font-serif text-lg font-semibold text-[#1F0D18] mb-6 leading-relaxed">
        <%= @today_content.question_text %>
      </p>
      <% if @today_response %>
        <div class="flex items-center gap-2 text-green-700 bg-green-50 rounded-xl px-4 py-3">
          <span>✓</span>
          <span class="text-sm font-medium">오늘 응답 완료</span>
        </div>
      <% else %>
        <%= link_to mission_path(@today_content),
            class: 'inline-flex items-center gap-2 bg-[#C2527A] hover:bg-[#8E3A6E] text-white px-6 py-3 rounded-xl font-semibold text-sm transition-colors' do %>
          오늘의 미션 시작하기 →
        <% end %>
        <p class="text-xs text-[#7A4868] mt-3">오늘 질문이 기다리고 있어요. 한 줄도 괜찮습니다.</p>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(194,82,122,0.10)] p-6 text-center text-[#7A4868]">
      오늘의 콘텐츠가 아직 준비 중입니다.
    </div>
  <% end %>
<% else %>
  <div class="text-center py-16">
    <p class="font-serif text-2xl font-bold text-[#1F0D18] mb-4">북살롱에 오신 걸 환영합니다</p>
    <p class="text-[#7A4868] mb-8">현재 참여 중인 기수가 없습니다.</p>
    <%= link_to root_path, class: 'inline-block bg-[#C2527A] text-white px-8 py-3 rounded-xl font-semibold hover:bg-[#8E3A6E] transition-colors' do %>
      프로그램 알아보기
    <% end %>
  </div>
<% end %>
