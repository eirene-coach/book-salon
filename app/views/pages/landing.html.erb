<!-- Hero 섹션 -->
<section class="text-center py-24 px-4">
  <p class="text-sm font-medium text-[#C2527A] tracking-widest uppercase mb-4">4주 비대면 북코칭 프로그램</p>
  <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1F0D18] leading-tight mb-6">
    어린이집 후 2시간,<br>
    <span class="text-[#C2527A]">나를 찾는 시간</span>
  </h1>
  <p class="text-[#7A4868] text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
    아이를 보내고 돌아온 그 고요한 시간.<br>
    책 한 챕터와 코치의 질문 하나로 내 방향을 발견합니다.
  </p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
    <% if user_signed_in? %>
      <%= link_to dashboard_path,
          class: 'inline-block bg-[#C2527A] hover:bg-[#8E3A6E] text-white px-10 py-4 rounded-xl font-bold text-base transition-colors shadow-[0_4px_24px_rgba(194,82,122,0.30)]' do %>
        대시보드로 가기
      <% end %>
    <% else %>
      <%= link_to new_user_session_path,
          class: 'inline-block bg-[#C2527A] hover:bg-[#8E3A6E] text-white px-10 py-4 rounded-xl font-bold text-base transition-colors shadow-[0_4px_24px_rgba(194,82,122,0.30)]' do %>
        4주 여정 들어가기
      <% end %>
    <% end %>
  </div>
  <p class="text-xs text-[#7A4868] mt-4">신용카드 없이 시작 · 언제든 문의 가능</p>
</section>

<!-- Problem 섹션 -->
