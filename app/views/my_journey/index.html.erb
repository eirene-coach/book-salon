<div class="mb-8">
  <h1 class="font-serif text-2xl font-bold text-[#1F0D18] mb-1">나의 여정 일지</h1>
  <% if @enrollment %>
    <p class="text-sm text-[#7A4868]"><%= @responses.count %>개의 기록</p>
  <% end %>
</div>

<% if @enrollment %>
  <% if @completed %>
    <div class="bg-pink-50 border border-pink-200 rounded-2xl p-6 mb-8 text-center">
      <p class="font-serif text-xl font-bold text-[#C2527A] mb-2">🎉 4주 여정을 완주했습니다!</p>
      <%= link_to 'PDF 다운로드', download_journey_path,
          class: 'inline-block text-sm text-[#C2527A] underline mt-2' %>
    </div>
  <% end %>

  <div class="space-y-5">
    <% @responses.each do |r| %>
      <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(194,82,122,0.08)] p-6 border border-pink-50">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-semibold text-[#C2527A] bg-pink-50 px-3 py-1 rounded-full">
            Day <%= r.daily_content.day_number %>
          </span>
          <span class="text-xs text-[#7A4868]/60"><%= r.created_at.strftime('%m.%d') %></span>
        </div>
        <p class="text-sm text-[#7A4868] mb-3 italic leading-relaxed">
          "<%= r.daily_content.question_text %>"
        </p>
        <p class="text-[#1F0D18] leading-relaxed"><%= r.content %></p>

        <% if r.feedback_text.present? %>
          <div class="mt-4 p-4 bg-[#FFF0F6] rounded-xl border-l-4 border-[#C2527A]">
            <p class="text-xs text-[#C2527A] font-semibold mb-2">💬 코치 피드백</p>
            <p class="text-sm text-[#1F0D18] leading-relaxed"><%= r.feedback_text %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 text-[#7A4868]">
    <p>현재 참여 중인 기수가 없습니다.</p>
  </div>
<% end %>
