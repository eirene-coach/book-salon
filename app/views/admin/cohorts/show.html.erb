<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @cohort.program.title %></h1>
      <p class="text-sm text-gray-500"><%= @cohort.start_date.strftime('%Y.%m.%d') %> 시작 · <%= @enrollments.count %>명</p>
    </div>
    <%= link_to '← 어드민', admin_root_path, class: 'text-sm text-[#7A4868] hover:text-[#C2527A]' %>
  </div>

  <!-- 콘텐츠 현황 (Day 1~21) -->
  <div class="mb-10">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold text-[#1F0D18]">콘텐츠 현황 <span class="text-sm font-normal text-[#7A4868]">(<%= @daily_contents.count %>/21일 등록됨)</span></h2>
      <%= link_to '+ 콘텐츠 등록', new_admin_cohort_daily_content_path(@cohort),
          class: 'text-sm bg-[#C2527A] text-white px-4 py-2 rounded-xl hover:bg-[#8E3A6E] transition-colors' %>
    </div>

    <% content_by_day = @daily_contents.index_by(&:day_number) %>
    <div class="grid gap-2">
      <% (1..21).each do |day| %>
        <% content = content_by_day[day] %>
        <div class="bg-white border <%= content ? 'border-pink-100' : 'border-dashed border-pink-200' %> rounded-xl px-4 py-3 flex items-center gap-4">
          <span class="flex-shrink-0 w-12 h-8 flex items-center justify-center rounded-lg text-xs font-bold <%= content ? 'bg-[#C2527A] text-white' : 'bg-pink-50 text-[#C2527A]' %>">
            Day <%= day %>
          </span>
          <% if content %>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-[#1F0D18] font-medium truncate"><%= content.question_text.presence || '질문 없음' %></p>
              <p class="text-xs text-[#7A4868]/60 truncate"><%= content.video_url %></p>
            </div>
            <div class="flex gap-2 flex-shrink-0">
              <%= link_to '수정', edit_admin_cohort_daily_content_path(@cohort, content),
                  class: 'text-xs text-[#7A4868] border border-pink-200 px-3 py-1.5 rounded-lg hover:bg-pink-50 transition-colors' %>
              <%= button_to '삭제', admin_cohort_daily_content_path(@cohort, content),
                  method: :delete,
                  form: { data: { turbo_confirm: "Day #{day} 콘텐츠를 삭제할까요?" } },
                  class: 'text-xs text-red-400 border border-red-100 px-3 py-1.5 rounded-lg hover:bg-red-50 transition-colors cursor-pointer bg-transparent' %>
            </div>
          <% else %>
            <p class="flex-1 text-sm text-[#7A4868]/40">미등록</p>
            <%= link_to '+ 등록', new_admin_cohort_daily_content_path(@cohort, daily_content: { day_number: day }),
                class: 'flex-shrink-0 text-xs text-[#C2527A] border border-pink-200 px-3 py-1.5 rounded-lg hover:bg-pink-50 transition-colors' %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-8">
    <h2 class="font-bold mb-3">출석 현황</h2>
    <table class="w-full text-sm border rounded-xl overflow-hidden">
      <thead class="bg-gray-50">
        <tr>
          <th class="text-left p-3">수강생</th>
          <th class="text-center p-3">제출 횟수</th>
          <th class="text-center p-3">스트릭</th>
        </tr>
      </thead>
      <tbody>
        <% @attendance.each do |att| %>
          <tr class="border-t">
            <td class="p-3"><%= att[:user].name %></td>
            <td class="text-center p-3"><%= att[:count] %>일</td>
            <td class="text-center p-3"><%= att[:streak] %>일 연속 🔥</td>
          </tr>
        <% end %>
        <% if @attendance.empty? %>
          <tr><td colspan="3" class="text-center p-4 text-gray-400">수강생이 없습니다.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <h2 class="font-bold mb-3">피드백 대기 중</h2>
  <% unfeedback = Response.where(feedback_text: [nil, '']).joins(:enrollment).where(enrollments: { cohort: @cohort }).includes({ enrollment: :user }, :daily_content) %>
  <div class="space-y-3">
    <% unfeedback.each do |r| %>
      <div class="bg-white border rounded-xl p-4">
        <div class="flex justify-between mb-2">
          <span class="font-medium text-sm"><%= r.enrollment.user.name %> · Day <%= r.daily_content.day_number %></span>
          <span class="text-xs text-gray-400"><%= r.created_at.strftime('%m.%d %H:%M') %></span>
        </div>
        <p class="text-sm text-gray-700 mb-3"><%= r.content %></p>
        <%= form_with url: admin_cohort_response_path(@cohort, r), method: :patch, class: 'flex gap-2' do |f| %>
          <%= f.text_area :feedback_text, placeholder: '따뜻한 피드백을 작성해주세요...', rows: 2,
              class: 'flex-1 border rounded-lg p-2 text-sm', name: 'response[feedback_text]' %>
          <%= f.submit '전송', class: 'bg-pink-600 text-white px-4 rounded-lg text-sm cursor-pointer' %>
        <% end %>
      </div>
    <% end %>
    <% if unfeedback.empty? %>
      <p class="text-center text-gray-400 py-8">🎉 모든 응답에 피드백을 완료했습니다!</p>
    <% end %>
  </div>
</div>
