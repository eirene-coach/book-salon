<%= form_with model: [:admin, @cohort, @content] do |f| %>
  <div class="space-y-5">
    <div>
      <%= f.label :day_number, 'Day 번호', class: 'block text-sm font-medium text-[#7A4868] mb-1.5' %>
      <%= f.number_field :day_number, min: 1, max: 21,
          class: 'w-full border border-pink-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#C2527A]/30 focus:border-[#C2527A] transition-all',
          placeholder: '1 ~ 21' %>
      <p class="text-xs text-[#7A4868]/60 mt-1">오리엔테이션은 Day 0 또는 별도 관리</p>
    </div>

    <div>
      <%= f.label :video_url, '유튜브 영상 URL', class: 'block text-sm font-medium text-[#7A4868] mb-1.5' %>
      <%= f.url_field :video_url,
          placeholder: 'https://www.youtube.com/watch?v=...',
          class: 'w-full border border-pink-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#C2527A]/30 focus:border-[#C2527A] transition-all font-mono' %>
      <p class="text-xs text-[#7A4868]/60 mt-1">유튜브 개별 영상 URL을 붙여넣으세요 (플레이리스트 URL 아님)</p>
    </div>

    <% if @content.persisted? && @content.video_url.present? %>
      <div>
        <p class="text-xs font-medium text-[#7A4868] mb-2">현재 영상 미리보기</p>
        <div class="relative pb-[56.25%] h-0 overflow-hidden rounded-xl bg-pink-50">
          <%= raw embed_video(@content.video_url) %>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :question_text, '코칭 질문', class: 'block text-sm font-medium text-[#7A4868] mb-1.5' %>
      <%= f.text_area :question_text, rows: 4,
          placeholder: '오늘 이 챕터를 읽으면서 어떤 문장이 당신을 멈추게 했나요?',
          class: 'w-full border border-pink-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#C2527A]/30 focus:border-[#C2527A] transition-all resize-none' %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit @content.persisted? ? '저장' : '등록',
          class: 'flex-1 bg-[#C2527A] hover:bg-[#8E3A6E] text-white py-3 rounded-xl font-semibold text-sm transition-colors cursor-pointer' %>
      <%= link_to '취소', admin_cohort_path(@cohort),
          class: 'flex-1 text-center border border-pink-200 text-[#7A4868] py-3 rounded-xl font-semibold text-sm hover:bg-pink-50 transition-colors' %>
    </div>
  </div>
<% end %>
