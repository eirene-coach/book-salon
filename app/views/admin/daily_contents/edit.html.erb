<div class="max-w-lg mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← #{@cohort.program.title}", admin_cohort_path(@cohort), class: 'text-sm text-[#7A4868] hover:text-[#C2527A]' %>
  </div>
  <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(194,82,122,0.08)] p-8 border border-pink-50">
    <h1 class="font-serif text-xl font-bold text-[#1F0D18] mb-1">Day <%= @content.day_number %> 수정</h1>
    <p class="text-sm text-[#7A4868] mb-6"><%= @cohort.start_date.strftime('%Y.%m.%d') %> 시작 기수</p>
    <%= render 'form' %>
  </div>
</div>
