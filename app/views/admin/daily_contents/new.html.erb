<div class="max-w-lg mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-2">콘텐츠 등록</h1>
  <p class="text-sm text-gray-500 mb-6"><%= @cohort.program.title %> · <%= @cohort.start_date.strftime('%Y.%m.%d') %></p>
  <%= form_with model: [:admin, @cohort, @content] do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :day_number, 'Day 번호', class: 'block text-sm font-medium mb-1' %>
        <%= f.number_field :day_number, min: 1, max: 28, class: 'w-full border rounded-lg p-2' %>
      </div>
      <div>
        <%= f.label :video_url, '영상 URL (YouTube/Vimeo)', class: 'block text-sm font-medium mb-1' %>
        <%= f.url_field :video_url, placeholder: 'https://www.youtube.com/watch?v=...', class: 'w-full border rounded-lg p-2' %>
      </div>
      <div>
        <%= f.label :question_text, '코칭 질문', class: 'block text-sm font-medium mb-1' %>
        <%= f.text_area :question_text, rows: 3, placeholder: '오늘 이 챕터를 읽으면서...', class: 'w-full border rounded-lg p-2' %>
      </div>
      <%= f.submit '등록', class: 'w-full bg-pink-600 text-white py-3 rounded-lg font-semibold cursor-pointer' %>
    </div>
  <% end %>
</div>
